{
  "name": "stock-widget",
  "version": "1.0.0",
  "description": "macOS menubar stock widget",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "build": "vite build",
    "start": "vite build && electron .",
    "dist": "vite build && electron-builder",
    "postinstall": "node scripts/generate-icon.js"
  },
  "build": {
    "appId": "com.tylerbrock.stock-widget",
    "productName": "Stock Widget",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.finance",
      "icon": "assets/icon.png",
      "target": [
        { "target": "dmg", "arch": ["arm64", "x64"] }
      ],
      "extendInfo": {
        "LSUIElement": true
      }
    },
    "dmg": {
      "title": "Stock Widget"
    }
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "electron": "^33.0.0",
    "electron-builder": "^26.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^5.4.0",
    "wait-on": "^8.0.1"
  }
}
